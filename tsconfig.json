{
  "compilerOptions": {
    "lib": ["esnext", "dom"],
    "strict": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "target": "ES2022",
    "skipLibCheck": true
  },
  "include": ["src", "tsdown.config.ts", "vitest.config.ts"],
  "exclude": ["dist", "node_modules"]
}
