{
  "name": "@auraimage/sdk",
  "version": "0.3.1",
  "description": "Official Auraimage SDK — server-side HMAC upload token signing.",
  "keywords": [
    "auraimage",
    "image-upload",
    "hmac",
    "upload-token",
    "cloudflare",
    "r2",
    "signed-upload"
  ],
  "homepage": "https://auraimage.ai",
  "bugs": {
    "url": "https://github.com/auraimage/sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/auraimage/sdk.git"
  },
  "license": "MIT",
  "author": "Auraimage <hello@auraimage.ai>",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./server": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "./package.json": "./package.json"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.39.4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.8.2",
    "tsdown": "^0.10.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^4.0.18"
  }
}
